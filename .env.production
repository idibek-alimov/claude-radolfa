# =============================================================================
# Radolfa — Production Environment Variables
# =============================================================================
# LOCATION ON VPS: /opt/radolfa/.env.production
# NEVER commit this file to git — it is in .gitignore
#
# To generate secrets:
#   POSTGRES_PASSWORD : openssl rand -base64 32
#   JWT_SECRET        : openssl rand -base64 64
#   SYSTEM_API_KEY    : openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=radolfa_db
POSTGRES_USER=radolfa_prod
POSTGRES_PASSWORD=kyVy08z4rdJ1t+FFwDM1d+7PlmmaRYefP6firA/ih0E=

# Internal only — no external port binding in docker-compose.prod.yml
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Elasticsearch — heap tuned for 4 GB VPS (test deployment)
# Increase ES_HEAP_SIZE when you upgrade the VPS
# -----------------------------------------------------------------------------
ELASTICSEARCH_PORT=9200
ES_HEAP_SIZE=256m

# -----------------------------------------------------------------------------
# S3-Compatible Storage — Timeweb Cloud
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=HQT82IRDRUYNZSS2FI8F
AWS_SECRET_ACCESS_KEY=DDq31dE6ZkW1jRCS1LtDNgDkEwbaBt5R6gdUiOai
AWS_S3_REGION=ru-1
AWS_S3_ENDPOINT=https://s3.twcstorage.ru
AWS_S3_BUCKET=96862269-2691-42c6-84ee-15f60b431da7

# -----------------------------------------------------------------------------
# JWT Security
# -----------------------------------------------------------------------------
JWT_SECRET=aurja84hVXSUN5g7meR6aPvy8fqVHZIkxRZL85Hz/PB5P3HlQRxqhffN30tdLgPnQUiwhtp59wVgtQV5DPuZFw==
JWT_EXPIRATION_MS=900000

# -----------------------------------------------------------------------------
# ERPNext → Backend machine-to-machine API key
# Must match the value set in ERPNext: App Settings → system_api_key
# -----------------------------------------------------------------------------
SYSTEM_API_KEY=a968f622dc7d7365d9e8539ea48659c17b63ee1fcc37bc555e7b3b29de743ab8
ERP_BASE_URL=http://localhost:8000
# ERPNext API key + secret — generate in ERPNext: Settings → User → Administrator → API Access
# Leave blank until ERPNext credentials are created; app starts fine without them.
ERP_API_KEY=
ERP_API_SECRET=

# -----------------------------------------------------------------------------
# Spring Boot
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod

# -----------------------------------------------------------------------------
# JVM — bounded heap for 4 GB test VPS
# Raise -Xmx to 1g when you upgrade VPS RAM
# -----------------------------------------------------------------------------
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseContainerSupport -Djava.security.egd=file:/dev/./urandom

# -----------------------------------------------------------------------------
# Docker image tag — updated automatically by GitHub Actions on each deploy
# To pin a specific deploy: set to the 8-char git SHA (e.g. a1b2c3d4)
# -----------------------------------------------------------------------------
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Ports — nginx handles 80/443 externally; all others are internal only
# -----------------------------------------------------------------------------
BACKEND_PORT=8080
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Frontend public API URL — baked into Next.js at build time via GitHub Actions
# These values here are for documentation only; update GitHub Actions secrets.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://api.radolfa.site
NEXT_PUBLIC_API_URL=https://api.radolfa.site
