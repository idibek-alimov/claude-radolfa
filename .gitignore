# =============================================================================
# Radolfa Project - Git Ignore Rules
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets (CRITICAL - Never commit these!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
# Production secrets file — contains real credentials, lives on VPS only
.env.production
# Local developer credentials — never commit (use application-local.yml.example as template)
backend/src/main/resources/application-local.yml
*.pem
*.key
credentials.json
secrets.yml
secrets.yaml

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Java / Maven (Backend)
# -----------------------------------------------------------------------------
backend/target/
backend/*.jar
backend/*.war
backend/*.ear
backend/pom.xml.tag
backend/pom.xml.releaseBackup
backend/pom.xml.versionsBackup
backend/pom.xml.next
backend/release.properties
backend/dependency-reduced-pom.xml
backend/buildNumber.properties
backend/.mvn/timing.properties
backend/.mvn/wrapper/maven-wrapper.jar

# -----------------------------------------------------------------------------
# Node / npm (Frontend)
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/install-state.gz
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

frontend-new/node_modules/
frontend-new/.next/
frontend-new/out/
frontend-new/.pnp
frontend-new/.pnp.js
frontend-new/.yarn/install-state.gz
frontend-new/npm-debug.log*
frontend-new/yarn-debug.log*
frontend-new/yarn-error.log*

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

frontend-new/.vercel
frontend-new/*.tsbuildinfo
frontend-new/next-env.d.ts

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Docker volumes data (if stored locally)
docker-volumes/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
log/

# -----------------------------------------------------------------------------
# Test & Coverage
# -----------------------------------------------------------------------------
backend/coverage/
backend/test-results/
frontend/coverage/
frontend/.nyc_output/

frontend-new/coverage/
frontend-new/.nyc_output/

# -----------------------------------------------------------------------------
# Build artifacts
# -----------------------------------------------------------------------------
dist/
build/
*.class
*.dll
*.exe
*.o
*.so

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
